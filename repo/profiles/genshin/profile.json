{
  "id": "genshin",
  "name": "原神",
  "icon": "🎮",
  "version": 3,
  "recommendedPlugins": [
    "genshin-direction-marker",
    "smart-cursor-detection",
    "bilibili-page-list",
    "akasha-genshin-automation"
  ],
  "activation": {
    "processes": ["GenshinImpact", "YuanShen"],
    "autoSwitch": true
  },
  "defaults": {
    "url": "https://www.bilibili.com"
  },
  "pluginConfigs": {
    "smart-cursor-detection": {
      "processWhitelist": "YuanShen, GenshinImpact",
      "minOpacity": 0.2
    }
  }
}
