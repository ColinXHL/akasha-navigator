<UserControl x:Class="AkashaNavigator.Views.Pages.ProfileMarketPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pages="clr-namespace:AkashaNavigator.ViewModels.Pages"
             Background="Transparent"
             Cursor="Arrow">

    <!-- 已移除本地资源定义，使用全局样式：
         - BoolToVisibilityConverter -> 全局 Converters.xaml
         - InverseBoolToVisibilityConverter -> 全局 Converters.xaml
         - ZeroToVisibleConverter -> 全局 Converters.xaml
         - LocalPrimaryButtonStyle -> 全局 PrimaryActionButtonStyle -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Profile 市场" FontSize="18" FontWeight="SemiBold"
                       Foreground="White" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="⚙ 订阅源管理"
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding ManageSourcesCommand}"/>
        </Grid>

        <!-- 搜索框 -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Style="{StaticResource SearchBoxStyle}" Tag="搜索 Profile..."
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Grid.Column="1" Content="🔄 刷新"
                    Style="{StaticResource ActionButtonStyle}"
                    Command="{Binding RefreshCommand}" Margin="8,0,0,0"/>
        </Grid>

        <!-- 内容区域 -->
        <ScrollViewer Grid.Row="2" Style="{StaticResource DarkScrollViewer}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 加载状态 -->
                <TextBlock Text="正在加载..."
                           Foreground="#888" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,40,0,40"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- 错误提示 -->
                <Border Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="#3A1A1A" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Foreground="#F87171" FontSize="13"
                                   TextWrapping="Wrap" VerticalAlignment="Center"
                                   Text="{Binding ErrorMessage}"/>
                        <Button Grid.Column="1" Content="重试"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding RefreshCommand}" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <!-- 无 Profile 提示 -->
                <TextBlock
                           Text="暂无可用的 Profile，可点击「订阅源管理」添加第三方订阅源"
                           Foreground="#888" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,40,0,40"
                           Visibility="{Binding HasNoProfiles, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- 无结果提示 -->
                <TextBlock
                           Text="没有找到匹配的 Profile"
                           Foreground="#666" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,40,0,40"
                           Visibility="{Binding HasNoResults, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Profile 列表 -->
                <ItemsControl ItemsSource="{Binding Profiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource InnerPluginCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Profile 信息 -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📦" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}" Foreground="White"
                                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                             <TextBlock Text="{Binding Version, StringFormat=' v{0}'}"
                                                        Foreground="#666" FontSize="11"
                                                        VerticalAlignment="Center" Margin="6,0,0,0"/>
                                            <Border Margin="8,0,0,0" VerticalAlignment="Center"
                                                    Background="#3A3218" CornerRadius="3" Padding="6,2"
                                                    Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="{Binding UpdateTagText}"
                                                           Foreground="#FACC15" FontSize="10"/>
                                            </Border>
                                            <!-- 目标游戏标签 -->
                                            <Border Margin="8,0,0,0" VerticalAlignment="Center"
                                                    Background="#1A3A5A" CornerRadius="3" Padding="6,2"
                                                    Visibility="{Binding HasTargetGame, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="{Binding TargetGame}"
                                                           Foreground="#60A5FA" FontSize="10"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" Foreground="#888" FontSize="11"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="400" Margin="0,4,0,0"
                                                   Visibility="{Binding HasDescription, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="{Binding Author, StringFormat='作者: {0}'}"
                                                       Foreground="#666" FontSize="11"
                                                       Visibility="{Binding HasAuthor, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <TextBlock Text=" · " Foreground="#444" FontSize="11"
                                                       Visibility="{Binding HasAuthor, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <TextBlock Text="{Binding PluginCount, StringFormat='{}{0} 个插件'}"
                                                       Foreground="#666" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 操作按钮 -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="详情" Style="{StaticResource ActionButtonStyle}"
                                                Command="{Binding DataContext.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" Margin="0,0,8,0"/>
                                        <!-- 安装按钮：未安装时显示 -->
                                        <Button Content="安装" Style="{StaticResource PrimaryActionButtonStyle}"
                                                Command="{Binding DataContext.InstallCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding ShowInstallButton, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <Button Content="更新" Style="{StaticResource PrimaryActionButtonStyle}"
                                                Command="{Binding DataContext.UpdateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" Margin="0,0,8,0"
                                                Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <!-- 卸载按钮：已安装且非默认 Profile 时显示 -->
                                        <Button Content="卸载" Style="{StaticResource ActionButtonStyle}"
                                                Command="{Binding DataContext.UninstallCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding ShowUninstallButton, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <!-- 已安装标签：已安装但是默认 Profile 时显示 -->
                                        <Border Background="#2A3A2A" CornerRadius="4" Padding="12,6"
                                                Visibility="{Binding IsDefaultAndInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="已安装" Foreground="#4ADE80" FontSize="12"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
