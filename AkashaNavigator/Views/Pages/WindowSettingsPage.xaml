<UserControl x:Class="AkashaNavigator.Views.Pages.WindowSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:controls="clr-namespace:AkashaNavigator.Controls"
             Background="Transparent"
             Cursor="Arrow">

    <StackPanel>
            <!-- 标题 -->
            <TextBlock Text="窗口设置" FontSize="18" FontWeight="SemiBold"
                       Foreground="White" Margin="0,0,0,16"/>

            <!-- 窗口行为 -->
            <TextBlock Text="窗口行为" Style="{StaticResource SettingsGroupHeaderStyle}"/>
            <CheckBox x:Name="EdgeSnapCheckBox" Content="启用边缘吸附"
                      Style="{StaticResource DarkCheckBoxStyle}" Margin="0,0,0,12"
                      IsChecked="{Binding EnableEdgeSnap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="吸附阈值" Style="{StaticResource SettingsLabelStyle}"/>
                <Slider x:Name="SnapThresholdSlider" Grid.Column="1"
                        Style="{StaticResource DarkSliderStyle}"
                        Minimum="5" Maximum="30" TickFrequency="5" IsSnapToTickEnabled="True"
                        Value="{Binding SnapThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="2" Text="{Binding SnapThreshold, StringFormat={}{0}px}"
                           Style="{StaticResource SettingsLabelStyle}" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="中点吸附阈值" Style="{StaticResource SettingsLabelStyle}"/>
                <Slider Grid.Column="1"
                        Style="{StaticResource DarkSliderStyle}"
                        Minimum="10" Maximum="60" TickFrequency="5" IsSnapToTickEnabled="True"
                        Value="{Binding CenterSnapThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="2" Text="{Binding CenterSnapThreshold, StringFormat={}{0}px}"
                           Style="{StaticResource SettingsLabelStyle}" HorizontalAlignment="Right"/>
            </Grid>
<CheckBox x:Name="PromptRecordOnExitCheckBox" Content="退出时提示记录"
                       Style="{StaticResource DarkCheckBoxStyle}" Margin="0,0,0,12"
                       IsChecked="{Binding PromptRecordOnExit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="关闭窗口时提示记录当前游戏进度笔记"
                        Foreground="#666" FontSize="11" Margin="0,0,0,24"/>
            <CheckBox x:Name="EnableOsdCheckBox" Content="启用 OSD 悬浮提示"
                       Style="{StaticResource DarkCheckBoxStyle}" Margin="0,0,0,8"
                       IsChecked="{Binding EnableOsd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="用于显示快捷键操作和窗口状态提示"
                        Foreground="#666" FontSize="11" Margin="0,0,0,24"/>

            <!-- 按住窥视 -->
            <TextBlock Text="按住窥视" Style="{StaticResource SettingsGroupHeaderStyle}"/>
            <CheckBox x:Name="EnableHoldToPeekCheckBox" Content="启用按住窥视"
                      Style="{StaticResource DarkCheckBoxStyle}" Margin="0,0,0,12"
                      IsChecked="{Binding EnableHoldToPeek, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="开启鼠标穿透后，按住窥视按键并将鼠标移动到播放器区域，可临时降低播放器透明度，方便查看下方游戏画面。松开按键或移出区域后自动恢复。"
                        Foreground="#666" FontSize="11" Margin="0,0,0,16"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="45"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="窥视透明度" Style="{StaticResource SettingsLabelStyle}"/>
                <Slider x:Name="PeekOpacitySlider" Grid.Column="1"
                        Style="{StaticResource DarkSliderStyle}"
                        Minimum="10" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="True"
                        Value="{Binding PeekOpacityPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="2" Text="{Binding PeekOpacityPercent, StringFormat={}{0:F0}%}"
                           Style="{StaticResource SettingsLabelStyle}" HorizontalAlignment="Right"/>
            </Grid>
            <TextBlock Text="窥视时播放器的显示透明度，越低越透明"
                        Foreground="#666" FontSize="11" Margin="0,0,0,24"/>
        </StackPanel>
</UserControl>
