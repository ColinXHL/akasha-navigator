<helpers:AnimatedWindow x:Class="AkashaNavigator.Views.Windows.PluginSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:AkashaNavigator.Helpers"
        Title="插件设置"
        Width="450"
        Height="500"
        MinWidth="350"
        MinHeight="300"
        WindowStartupLocation="CenterScreen"
        Foreground="White"
        ResizeMode="CanResize">

    <!-- 主容器带边框 -->
    <Border x:Name="MainContainer" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="8"
            RenderTransformOrigin="0.5,0.5" Opacity="0">
        <Border.RenderTransform>
            <ScaleTransform x:Name="ContainerScale" ScaleX="0.96" ScaleY="0.96"/>
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#252525" CornerRadius="8,8,0,0" 
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="🔧" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TitleText" Text="插件设置" FontSize="14" FontWeight="SemiBold" 
                                   Foreground="#EEE" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Style="{StaticResource TitleBarCloseButtonStyle}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- 内容区 -->
            <ScrollViewer Grid.Row="1" Style="{StaticResource DarkScrollViewer}" 
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SettingsContainer" Margin="20,16,20,16"/>
            </ScrollViewer>

            <!-- 按钮区 -->
            <Border Grid.Row="2" Background="#252525" CornerRadius="0,0,8,8" Padding="16,12">
                <Grid>
                    <Button x:Name="BtnReset" Content="重置" 
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Left"
                            Click="BtnReset_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnCancel" Content="取消" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnCancel_Click" Margin="0,0,8,0"/>
                        <Button x:Name="BtnSave" Content="保存"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="BtnSave_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</helpers:AnimatedWindow>
