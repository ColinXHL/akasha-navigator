<helpers:AnimatedWindow x:Class="AkashaNavigator.Views.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:AkashaNavigator.Helpers"
        xmlns:pages="clr-namespace:AkashaNavigator.Views.Pages"
        xmlns:vm="clr-namespace:AkashaNavigator.ViewModels.Windows"
        xmlns:settings="clr-namespace:AkashaNavigator.ViewModels.Pages.Settings"
        Title="设置"
        Width="700"
        Height="525"
        WindowStartupLocation="CenterScreen"
        Foreground="White"
        ResizeMode="CanResize"
        MinWidth="700"
        MinHeight="450">

    <!-- 主容器带边框 -->
    <Border x:Name="MainContainer" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="8"
            RenderTransformOrigin="0.5,0.5" Opacity="0">
        <Border.RenderTransform>
            <ScaleTransform x:Name="ContainerScale" ScaleX="0.96" ScaleY="0.96"/>
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#252525" CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="⚙️ 设置" FontSize="14" FontWeight="SemiBold"
                               Foreground="#EEE" VerticalAlignment="Center" Margin="16,0"/>
                    <Button Style="{StaticResource WindowCloseButtonStyle}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Click="BtnCancel_Click"/>
                </Grid>
            </Border>

            <!-- 主内容区 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧导航栏 -->
                <Border Grid.Column="0" Background="#252525" CornerRadius="0,0,0,8">
                    <StackPanel Margin="8,16,8,16">
                        <!-- 搜索框 -->
                        <Grid>
                            <TextBox x:Name="SearchBox"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                     Style="{StaticResource SearchBoxStyle}"
                                     Tag="搜索设置..."
                                     Margin="4,8,4,8"
                                     GotFocus="SearchBox_GotFocus"/>

                            <!-- 搜索结果悬浮窗 -->
                            <Popup x:Name="SearchResultsPopup"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=SearchBox}"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border Background="#2A2A2A"
                                        BorderBrush="#444"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8,4"
                                        Width="156"
                                        MaxHeight="250">
                                    <ScrollViewer Style="{StaticResource DarkScrollViewer}" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding SearchResults}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource SearchResultButtonStyle}"
                                                            Command="{Binding DataContext.NavigateToSearchResultCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Content="{Binding DisplayText}"
                                                            Padding="12,6"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Popup>

                            <!-- 无结果提示（Popup） -->
                            <Popup x:Name="NoResultsPopup"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=SearchBox}"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border Background="#2A2A2A"
                                        BorderBrush="#444"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12,8"
                                        Width="156">
                                    <TextBlock Text="未找到相关设置" Foreground="#888" FontSize="12"/>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- 导航按钮 -->
                        <RadioButton x:Name="NavGeneral" Content="⚙️ 通用"
                                     Style="{StaticResource NavRadioButtonStyle}"
                                     Command="{Binding NavigateToGeneralCommand}"
                                     IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static settings:SettingsPageType.General}}"/>
                        <RadioButton x:Name="NavWindow" Content="🔲 窗口"
                                     Style="{StaticResource NavRadioButtonStyle}"
                                     Command="{Binding NavigateToWindowCommand}"
                                     IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static settings:SettingsPageType.Window}}"/>
                        <RadioButton x:Name="NavHotkeys" Content="⌨️ 快捷键"
                                     Style="{StaticResource NavRadioButtonStyle}"
                                     Command="{Binding NavigateToHotkeysCommand}"
                                     IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static settings:SettingsPageType.Hotkeys}}"/>
                        <RadioButton x:Name="NavAdvanced" Content="🔧 高级"
                                     Style="{StaticResource NavRadioButtonStyle}"
                                     Command="{Binding NavigateToAdvancedCommand}"
                                     IsChecked="{Binding CurrentPage, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static settings:SettingsPageType.Advanced}}"/>
                    </StackPanel>
                </Border>

                <!-- 右侧内容区 -->
                <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="0,0,8,0">
                    <ScrollViewer Style="{StaticResource DarkScrollViewer}" VerticalScrollBarVisibility="Auto">
                        <Grid x:Name="ContentArea" Margin="24,16">
                            <!-- Pages 将在代码后台中通过 DI 动态添加 -->
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- 底部按钮 -->
            <Border Grid.Row="2" Background="#252525" Padding="16,10" CornerRadius="0,0,8,8">
                <Grid>
                    <Button Content="重置" Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Left" Command="{Binding ResetCommand}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="取消" Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,0" Click="BtnCancel_Click"/>
                        <Button Content="保存" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveCommand}" Click="BtnSave_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</helpers:AnimatedWindow>
