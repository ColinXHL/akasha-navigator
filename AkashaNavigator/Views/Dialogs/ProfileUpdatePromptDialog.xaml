<helpers:AnimatedWindow x:Class="AkashaNavigator.Views.Dialogs.ProfileUpdatePromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:AkashaNavigator.Helpers"
        Title="Profile 更新"
        Width="400"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Foreground="White"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">

    <Border x:Name="MainContainer" Background="#2D2D2D" CornerRadius="8" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="ContainerScale" ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.6" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#252525" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🔄" FontSize="16"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1" Text="Profile 更新可用"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <Button Grid.Column="2"
                            Style="{StaticResource DialogCloseButtonStyle}"
                            Command="{Binding CancelCommand}"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="24,20">
                <StackPanel>
                    <TextBlock Text="🎮" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock TextWrapping="Wrap" FontSize="14"
                               Foreground="#DDD" LineHeight="22" TextAlignment="Center" Margin="0,0,0,16"
                               Text="{Binding UpdateMessage}"/>
                    <Border Height="1" Background="#3C3C3C" Margin="0,0,0,16"/>
                    <CheckBox Content="不再提示更新 (慎选)"
                              Style="{StaticResource DarkCheckBoxStyle}"
                              HorizontalAlignment="Center" Foreground="#888"
                              IsChecked="{Binding DontShowAgain}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="#252525" CornerRadius="0,0,8,8" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1" Content="打开插件中心"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0"
                            Command="{Binding OpenPluginCenterCommand}"/>
                    <Button Grid.Column="2" Content="一键更新"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,8,0"
                            Command="{Binding UpdateAllCommand}"/>
                    <Button Grid.Column="3" Content="取消"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding CancelCommand}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</helpers:AnimatedWindow>
