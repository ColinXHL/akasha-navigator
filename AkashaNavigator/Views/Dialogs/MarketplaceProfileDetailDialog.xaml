<helpers:AnimatedWindow x:Class="AkashaNavigator.Views.Dialogs.MarketplaceProfileDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:AkashaNavigator.Helpers"
        xmlns:vm="clr-namespace:AkashaNavigator.ViewModels.Dialogs"
        Title="Profile 详情" Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        Foreground="White" ResizeMode="NoResize">

    <Border Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Border Grid.Row="0" Background="#252525" CornerRadius="4,4,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Profile 详情" Foreground="White" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <Button Content="✕" Style="{StaticResource TitleBarCloseButtonStyle}"
                            HorizontalAlignment="Right" Command="{Binding CloseCommand}"/>
                </Grid>
            </Border>

            <!-- 内容区域 -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题区域 -->
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📦" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ProfileName}" FontSize="20" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ProfileVersion}" Foreground="#666" FontSize="14"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- 目标游戏标签 -->
                    <Border Margin="0,8,0,0"
                            Background="#1A3A5A" CornerRadius="3" Padding="8,4"
                            HorizontalAlignment="Left"
                            Visibility="{Binding ShowTargetGame, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding TargetGame}" Foreground="#60A5FA" FontSize="12"/>
                    </Border>
                </StackPanel>

                <!-- 内容区域 -->
                <ScrollViewer Grid.Row="1" Style="{StaticResource DarkScrollViewer}" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 描述 -->
                        <TextBlock Text="描述" Foreground="#AAA" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ProfileDescription}" Foreground="#CCC" FontSize="13"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <!-- 元信息 -->
                        <Border Background="#252525" CornerRadius="4" Padding="12" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="作者:" Foreground="#888" FontSize="12" Margin="0,0,12,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Author}" Foreground="White" FontSize="12" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="更新时间:" Foreground="#888" FontSize="12" Margin="0,0,12,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UpdatedAt}" Foreground="White" FontSize="12" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="插件数量:" Foreground="#888" FontSize="12" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PluginCount}" Foreground="White" FontSize="12"/>
                            </Grid>
                        </Border>

                        <!-- 插件列表 -->
                        <TextBlock Text="包含的插件" Foreground="#AAA" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding PluginList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#252525" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="🔌" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding PluginId}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <!-- 状态标签 -->
                                            <Border Grid.Column="1" CornerRadius="3" Padding="6,2"
                                                    Background="{Binding StatusBackground}">
                                                <TextBlock Text="{Binding StatusText}" 
                                                           Foreground="{Binding StatusForeground}" FontSize="10"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- 底部按钮 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="取消" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding CancelCommand}" Width="80" Margin="0,0,8,0"/>
                    <Button Content="{Binding PrimaryActionText}" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding InstallCommand}" Width="80"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</helpers:AnimatedWindow>
